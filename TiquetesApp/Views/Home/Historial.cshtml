@{
    ViewData["Title"] = "Historial de Compras";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">📋 Historial de Compras</h2>

<div id="tablaHistorial">
    <div class="text-center text-muted">Cargando historial...</div>
</div>

@section Scripts {
    <script>
        async function cargarHistorial() {
            try {
                const res = await fetch('/api/compras', { credentials: 'include' });

                if (res.status === 401) {
                    window.location.href = '/Account/Login';
                    return;
                }

                const compras = await res.json();
                const contenedor = document.getElementById('tablaHistorial');

                if (compras.length === 0) {
                    contenedor.innerHTML = '<div class="alert alert-info">No hay compras registradas.</div>';
                    return;
                }

                const filas = compras.map(c => `
                    <tr>
                        <td>${c.id}</td>
                        <td>${c.eventoNombre}</td>
                        <td>${c.nombreCliente}</td>
                        <td>${c.cantidad}</td>
                        <td>₡${c.total.toFixed(2)}</td>
                        <td>${new Date(c.fechaCompra).toLocaleString('es-CR')}</td>
                    </tr>
                `).join('');

                contenedor.innerHTML = `
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>Evento</th>
                                    <th>Cliente</th>
                                    <th>Cantidad</th>
                                    <th>Total</th>
                                    <th>Fecha</th>
                                </tr>
                            </thead>
                            <tbody>${filas}</tbody>
                        </table>
                    </div>
                `;
            } catch {
                document.getElementById('tablaHistorial').innerHTML =
                    '<div class="alert alert-danger">Error al cargar el historial.</div>';
            }
        }

        cargarHistorial();
    </script>
}
